{
  "name": "nodemower",
  "version": "0.1.0",
  "description": "Reclaim disk space by finding and cleaning up node_modules directories and JavaScript package manager caches.",
  "keywords": [
    "node_modules",
    "cleanup",
    "disk-space",
    "cache",
    "npm",
    "pnpm",
    "yarn",
    "bun",
    "deno",
    "cli",
    "housekeeping"
  ],
  "homepage": "https://github.com/carlos-dubon/nodemower#readme",
  "bugs": {
    "url": "https://github.com/carlos-dubon/nodemower/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlos-dubon/nodemower.git"
  },
  "license": "MIT",
  "author": "Carlos Daniel Dubón",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "nodemower": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.2",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "picocolors": "^1.1.1",
    "pretty-bytes": "^7.1.0",
    "rimraf": "^6.1.3",
    "untildify": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
